rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation helpers
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 100 &&
             data.createdAt == request.time;
    }

    function isValidContact(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.message is string && data.message.size() <= 2000 &&
             (data.createdAt == request.time || data.createdAt is timestamp);
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['userId', 'trekId', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.trekId is string && data.trekId.size() <= 100 &&
             data.status in ['pending', 'contacted', 'confirmed', 'cancelled'] &&
             data.createdAt == request.time;
    }

    function isValidFavorite(data) {
      return data.keys().hasAll(['userId', 'trekId', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.trekId is string && data.trekId.size() <= 100 &&
             data.createdAt == request.time;
    }

    // Collections
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidUser(incoming()) && userId == request.auth.uid;
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin']);
    }

    match /contacts/{contactId} {
      allow create: if isValidContact(incoming());
      allow read, update, delete: if false;
    }

    match /inquiries/{inquiryId} {
      allow create: if isSignedIn() && isValidInquiry(incoming());
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }

    match /favoriteTreks/{favId} {
      allow create: if isSignedIn() && isValidFavorite(incoming());
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid);
    }
  }
}
