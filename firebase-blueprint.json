{
  "entities": {
    "Contact": {
      "title": "Contact Submission",
      "description": "Information submitted via the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the sender" },
        "email": { "type": "string", "format": "email", "description": "Email address of the sender" },
        "message": { "type": "string", "description": "The message text" },
        "tripInterest": { "type": "string", "description": "The specific trip or region the user is interested in" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the submission was made" }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "Registered user account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Inquiry": {
       "title": "Trip Inquiry",
       "description": "Specific trip inquiry from a user",
       "type": "object",
       "properties": {
         "userId": { "type": "string" },
         "trekId": { "type": "string" },
         "trekTitle": { "type": "string" },
         "status": { "type": "string", "enum": ["pending", "contacted", "confirmed", "cancelled"] },
         "createdAt": { "type": "string", "format": "date-time" }
       },
       "required": ["userId", "trekId", "status", "createdAt"]
    },
    "FavoriteTrek": {
      "title": "Favorite Trek",
      "description": "A trek favorited by a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "trekId": { "type": "string" },
        "trekTitle": { "type": "string" },
        "trekImage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "trekId", "createdAt"]
    }
  },
  "firestore": {
    "contacts": {
      "schema": "Contact",
      "description": "Collection for contact form submissions"
    },
    "users": {
      "schema": "User",
      "description": "Registered users"
    },
    "inquiries": {
      "schema": "Inquiry",
      "description": "User inquiries for specific treks"
    },
    "favoriteTreks": {
      "schema": "FavoriteTrek",
      "description": "User favorite treks"
    }
  }
}
